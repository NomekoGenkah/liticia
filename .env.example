DATABASE_URL=postgresql://user:password@postgres:5432/licitia
POSTGRES_USER=licitia
POSTGRES_PASSWORD=password
POSTGRES_DB=licitia

CHILECOMPRA_TICKET=your-ticket-here
CHILECOMPRA_API_BASE=https://api.mercadopublico.cl/servicios/v1/publico
# Tope propio de requests diarias a ChileCompra, para no gastar la cuota del ticket sin darte cuenta.
# El límite real de la API es 10.000 diarias por ticket y no es modificable, así que este valor solo
# tiene sentido igual o menor. Al alcanzarlo, la ingesta corta sola con un 429 LIMITE_LOCAL_REQUESTS
# (es tu propio guardarraíl, no un rechazo de ChileCompra). El contador se reinicia cada día.
CHILECOMPRA_MAX_REQUESTS_DIA=10000
CHILECOMPRA_REQUEST_TIMEOUT_MS=15000
CHILECOMPRA_RETRY_MAX=3
CHILECOMPRA_RETRY_BASE_DELAY_MS=500

OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3:8b
OLLAMA_REQUEST_TIMEOUT_MS=60000
OLLAMA_RETRY_MAX=2
OLLAMA_RETRY_BASE_DELAY_MS=1000
# OLLAMA_THINK=true habilita el modo de razonamiento (chain-of-thought) en modelos híbridos como qwen3.
OLLAMA_THINK=false

# Modelo de embeddings para el RAG (`ollama pull nomic-embed-text`), separado del de chat.
# Debe ser de 768 dimensiones: la columna `vector(768)` y la validación del cliente lo asumen.
# Cambiarlo por otro de la misma familia obliga a re-embeber todo (los vectores viejos dejan de ser
# comparables); cambiarlo por otra familia además exige una migración de la columna. Los prefijos
# `search_document:`/`search_query:` que usa el servicio son específicos de nomic-embed-text.
OLLAMA_EMBED_MODEL=nomic-embed-text
# Cuántos chunks se embeben por llamada a Ollama.
OLLAMA_EMBED_BATCH_SIZE=16
# Timeout de la pregunta al LLM, aparte del de análisis/matching: el prompt de RAG lleva miles de
# tokens de contexto y en un modelo local el solo prompt eval puede tardar más que esos 60s.
OLLAMA_RAG_TIMEOUT_MS=180000
# Ventana de contexto de la pregunta. Ollama trunca el prompt en silencio a num_ctx (default 4096),
# descartando los tokens más viejos: con el default se perdería el system prompt y los fragmentos
# más relevantes, y el modelo respondería genérico sin ningún error visible.
OLLAMA_RAG_NUM_CTX=8192
# Cuántos fragmentos se recuperan como contexto de cada pregunta. Subirlo exige subir OLLAMA_RAG_NUM_CTX.
RAG_TOP_K=5

# SCHEDULE_MODE=cron: SCHEDULE_VALUE es una expresión cron de 5 campos (ej. "0 2 * * *" = 2am diario).
# SCHEDULE_MODE=interval: SCHEDULE_VALUE es un entero en milisegundos (ej. "3600000" = cada hora).
SCHEDULE_MODE=cron
SCHEDULE_VALUE=0 2 * * *

STORAGE_LOGS_DIR=./storage/logs
STORAGE_DOCUMENTOS_DIR=./storage/documentos

PORT=3000
LOG_LEVEL=info
NODE_ENV=development
