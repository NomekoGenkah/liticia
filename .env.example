DATABASE_URL=postgresql://user:password@postgres:5432/licitia
POSTGRES_USER=licitia
POSTGRES_PASSWORD=password
POSTGRES_DB=licitia

CHILECOMPRA_TICKET=your-ticket-here
CHILECOMPRA_API_BASE=https://api.mercadopublico.cl/servicios/v1/publico
CHILECOMPRA_MAX_REQUESTS_DIA=10000
CHILECOMPRA_REQUEST_TIMEOUT_MS=15000
CHILECOMPRA_RETRY_MAX=3
CHILECOMPRA_RETRY_BASE_DELAY_MS=500

OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3:8b

SCHEDULE_MODE=cron
SCHEDULE_VALUE=0 2 * * *

STORAGE_LOGS_DIR=./storage/logs

PORT=3000
LOG_LEVEL=info
NODE_ENV=development
