{
  "name": "licitia-backend",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "ingest": "tsx src/jobs/ingestarLicitaciones.ts",
    "analyze": "tsx src/jobs/analizarLicitaciones.ts",
    "match": "tsx src/jobs/matchearLicitaciones.ts",
    "embed": "tsx src/jobs/embeberDocumentos.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "dotenv -e ../.env -- prisma migrate dev",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "dotenv": "^16.6.1",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "mammoth": "^1.12.0",
    "multer": "^2.2.0",
    "node-cron": "^3.0.3",
    "ollama": "^0.6.3",
    "pdf-parse": "^2.4.5",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.10.5",
    "@types/node-cron": "^3.0.11",
    "dotenv-cli": "^11.0.0",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  }
}
